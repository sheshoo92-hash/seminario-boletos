# Copia este archivo a ".env" y rellena tus datos reales

# Token de PRODUCCION o PRUEBA de Mercado Pago (Access Token)
# Lo obtienes en: https://www.mercadopago.com.mx/developers/panel/app
MP_ACCESS_TOKEN=TU_ACCESS_TOKEN_AQUI

# URL pública donde quedará publicada tu app (Render, Railway, etc.)
# Ejemplo: https://mi-seminario.onrender.com
BASE_URL=http://localhost:3000

# Puerto del servidor
PORT=3000

# Contraseña para el panel de administración y el escáner de la puerta
ADMIN_PASSWORD=cambia-esta-clave

# Nombre del seminario (aparece en el boleto)
EVENT_NAME=Seminario Amway

# Precio único del boleto (en pesos MXN, sin decimales)
PRECIO_BOLETO=500
